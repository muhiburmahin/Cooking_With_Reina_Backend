generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// --- 1. User & Auth (Better Auth Compatible) ---
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          Role      @default(CLIENT)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  bookings      Booking[]
  reviews       Review[] 

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id           String   @id @default(cuid())
  userId       String
  providerId   String
  accountId    String
  password     String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

// --- 2. Menu Management (Culinary Collection) ---
model MenuCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?    @db.Text
  imageUrl    String?    
  order       Int        @default(0)
  items       MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id              String       @id @default(cuid())
  categoryId      String
  name            String
  slug            String       @unique
  description     String       @db.Text
  
  // Cooking Details (New & Essential)
  preparationTime String?     
  cookingTime     String?     
  servingSize     String?    
  ingredients     String[]     
  calories        Int?         
  
  flavorProfile   String?      
  price           Decimal?     @db.Decimal(10, 2)    
  thumbnailUrl    String?      
  publicId        String?     
  
  dietaryTags     String[]     // ["Halal", "Vegan", "Spicy"]
  isSignature     Boolean      @default(false) 
  isAvailable     Boolean      @default(true)
  isFeatured      Boolean      @default(false)
  
  averageRating   Float?       @default(0.0)
  order           Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  category        MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  media           MenuMedia[] 
  reviews         Review[]

  @@index([categoryId])
  @@index([slug])
  @@map("menu_items")
}

model MenuMedia {
  id         String    @id @default(cuid())
  url        String    
  publicId   String? 
  mediaType  MediaType @default(IMAGE) 
  menuItemId String
  menuItem   MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@map("menu_media")
}

// --- 3. Services & Event Packages ---
model Service {
  id           String    @id @default(cuid())
  name         String    @unique
  slug         String    @unique
  tagline      String?   
  description  String    @db.Text
  imageUrl     String?
  order        Int       @default(0)
  packages     Package[]
  bookings     Booking[]

  @@map("services")
}

model Package {
  id          String   @id @default(cuid())
  serviceId   String
  name        String   
  description String   @db.Text
  price       Decimal? @db.Decimal(10, 2)
  features    String[] 
  isPopular   Boolean  @default(false)
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("packages")
}

// --- 4. Booking, Reviews & Feedback ---
model Booking {
  id           String        @id @default(cuid())
  userId       String?
  serviceId    String
  clientName   String
  clientEmail  String
  clientPhone  String
  eventDate    DateTime
  guestCount   Int
  venueAddress String?
  budgetRange  BudgetRange
  specialNotes String?       @db.Text
  status       BookingStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([serviceId])
  @@map("bookings")
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  menuItemId String
  rating     Int      @default(5)
  comment    String?  @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@map("reviews")
}

// --- 5. Content & Social Proof ---
model Event {
  id          String   @id @default(cuid())
  title       String   
  slug        String   @unique
  description String   @db.Text
  imageUrl    String?
  eventDate   DateTime
  location    String
  isPublished Boolean  @default(false)

  @@map("events")
}

model Testimonial {
  id          String   @id @default(cuid())
  clientName  String
  clientTitle String?  
  message     String   @db.Text
  rating      Int      @default(5)
  isFeatured  Boolean  @default(false)

  @@map("testimonials")
}

model Gallery {
  id        String          @id @default(cuid())
  url       String
  publicId  String?
  mediaType MediaType       @default(IMAGE) 
  category  GalleryCategory @default(FOOD)
  order     Int             @default(0)

  @@map("gallery")
}

// --- 6. Enums ---
enum Role {
  ADMIN
  CLIENT
}

enum MediaType {
  IMAGE
  VIDEO
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum BudgetRange {
  RANGE_1000_3000
  RANGE_3000_5000
  RANGE_5000_10000
  ABOVE_10000
}

enum GalleryCategory {
  FOOD
  EVENTS
  SETUP
}